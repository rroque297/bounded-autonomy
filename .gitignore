# Dependencies — downloaded automatically by "npm install", never commit these
node_modules/

# Build output — generated by "npm run build", Vercel builds this itself
dist/

# Editor files — VS Code settings specific to your machine
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln

# Operating system files
.DS_Store        # macOS folder metadata
Thumbs.db        # Windows thumbnail cache

# Local environment variables (if you ever add secrets)
.env
.env.local
.env.production
